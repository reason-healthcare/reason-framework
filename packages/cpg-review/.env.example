# This project temporarily uses enviroment variables to set content endpoint and plan definition identifier. In the future, there will be client side capability for setting these.
# Examples are from IG https://github.com/reason-healthcare/interactive-cds-content

# Set local file path to CPG content
PATH_TO_CONTENT="file:///{{project-foler}}/interactive-cds-content/output"

# Set plan definition canonical as identifier
PLAN_DEFINITION_IDENTIFIER="http://example.org/PlanDefinition/RheumatoidArthritisGuideline"

# Local Ollama runtime settings for LLM-powered questionnaire recommendations
# Start Ollama locally: https://ollama.com/
# Check available models: ollama list
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="mistral:7b"

